# --- Binaires compilés (distribués via les GitHub Releases, pas dans le dépôt) ---
*.exe
*.apk
*.apk.idsig
*.AppImage
*.ipa

# --- App Linux (Electron) : dépendances et sorties de build ---
linux/node_modules/
linux/dist/
# renderer/ est généré depuis android/assets/index.html par copy-web.js
linux/renderer/

# --- App iOS : projet Xcode généré (xcodegen) et sorties de build ---
ios/GamingDaily.xcodeproj/
ios/build/
ios/Payload/
# index.html est copié depuis android/assets/index.html par la CI
ios/GamingDaily/index.html

# --- Clés de signature : NE JAMAIS committer ---
# Perdre ou exposer cette clé compromet la signature des mises à jour.
*.jks
*.keystore

# --- Artefacts de build Android (regénérés par build_apk.ps1) ---
android/build/

# --- Sorties temporaires ---
*_magazine.html
*_run.ps1
*.tmp

# --- Divers OS / éditeurs ---
Thumbs.db
desktop.ini
.DS_Store
.vscode/
